# API Gateway endpoint URL (e.g., https://xxxxxxxxxx.execute-api.us-east-1.amazonaws.com/prod)
VITE_API_URL=

# Amazon Cognito User Pool ID (e.g., us-east-1_xxxxxxxxx)
VITE_USER_POOL_ID=

# Amazon Cognito User Pool Client ID (e.g., xxxxxxxxxxxxxxxxxxxxxxxxxx)
VITE_USER_POOL_CLIENT_ID=

# Amazon Cognito Identity Pool ID (e.g., us-east-1:xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx)
VITE_IDENTITY_POOL_ID=

# S3 bucket name for audio file storage
VITE_AUDIO_BUCKET_NAME=

# AWS region (e.g., us-east-1)
VITE_AWS_REGION=

# Nova Sonic proxy server URL (local Express + Socket.IO server)
VITE_SONIC_SERVER_URL=http://localhost:3001

# WebSocket URL for Nova Sonic real-time speaking sessions (OPTIONAL — kept for backward compatibility, no longer required for speaking module)
VITE_WEBSOCKET_URL=
